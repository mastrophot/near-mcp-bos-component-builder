{
  "name": "mcp-near-bos-component-builder",
  "version": "0.1.0",
  "description": "MCP server for scaffolding BOS components and automating NEAR Social deployment",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-near-bos-component-builder": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "check": "npm run build && npm run test",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "near",
    "bos",
    "builder",
    "model-context-protocol"
  ],
  "author": "Mastrophot",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
